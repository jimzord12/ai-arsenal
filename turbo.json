{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    ".bun-version",
    ".nvmrc",
    "eslint.config.mjs",
    "prettier.config.mjs",
    "tsconfig.json"
  ],
  "tasks": {
    "format": {
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^typecheck"],
      "outputs": ["coverage/**"]
    },
    "pack": {
      "dependsOn": ["test"],
      "outputs": ["*.tgz"]
    },
    "validate": {
      "dependsOn": ["pack"],
      "outputs": []
    }
  }
}
