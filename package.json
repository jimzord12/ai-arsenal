{
  "name": "ai-arsenal",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for AI-driven software-development tools.",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.5.0",
    "pnpm": "10.33.0"
  },
  "scripts": {
    "prepare": "husky",
    "format": "turbo run format",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "lint": "turbo run lint",
    "lint:root": "eslint .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:workflow": "node --test scripts/validate-monorepo-work-item.test.mjs",
    "pack": "turbo run pack",
    "validate": "turbo run validate",
    "validate:workflow": "node scripts/validate-living-workflow.mjs && node scripts/validate-monorepo-work-item.mjs --work-item none --json",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm test:workflow && pnpm validate:workflow",
    "changeset": "changeset",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "10.0.1",
    "@types/jest": "29.5.14",
    "@types/node": "24.5.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "husky": "9.1.7",
    "jest": "29.7.0",
    "lint-staged": "17.0.8",
    "prettier": "3.9.5",
    "publint": "0.3.21",
    "turbo": "2.10.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
